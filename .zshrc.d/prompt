autoload -Uz vcs_info
zstyle ':vcs_info:git:*' formats ' %b'

# Enable prompt substitution
setopt PROMPT_SUBST

precmd() {
  vcs_info
}

# disable python virtuelenv prompt mangling
export VIRTUAL_ENV_DISABLE_PROMPT=true

# Simple but informative prompt
PROMPT=$'[%n@%m] %F{magenta}${VIRTUAL_ENV:+"${VIRTUAL_ENV##*/} "}%f$(kube_prompt)%F{blue}%2~%f$vcs_info_msg_0_ \n\(%(?.%?.%F{red}%?%f)\)%(!.#.$) '
